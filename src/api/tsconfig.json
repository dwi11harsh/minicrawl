{
	"compilerOptions": {
		"lib": ["ESNext", "dom"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		"baseUrl": ".",
		"paths": {
			"@mc/types": ["../../types/src/index.ts"],
			"@mc/types/*": ["../../types/src/*"],
			"@mc/redis": ["../../services/redis/src/index.ts"],
			"@mc/redis/*": ["../../services/redis/src/*"],
			"@mc/db": ["../../services/db/src/index.ts"],
			"@mc/db/*": ["../../services/db/src/*"],
			"@mc/logger": ["../../services/logger/index.ts"]
		},

		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false
	}
}
