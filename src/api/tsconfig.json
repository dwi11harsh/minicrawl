{
	"compilerOptions": {
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		"baseUrl": ".",
		"paths": {
			"@minicrawl/types": ["../../types/src/index.ts"],
			"@minicrawl/types/*": ["../../types/src/*"],
			"@minicrawl/redis": ["../../services/redis/src/index.ts"],
			"@minicrawl/redis/*": ["../../services/redis/src/*"],
			"@minicrawl/db": ["../../services/db/src/index.ts"],
			"@minicrawl/db/*": ["../../services/db/src/*"]
		},

		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false
	}
}
