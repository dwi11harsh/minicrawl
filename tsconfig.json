{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "rootDir": "./src",
    "lib": ["ES2022", "DOM"],

    // or higher
    "target": "ES2022",

    "module": "NodeNext",
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "./dist/src",
    "moduleResolution": "NodeNext",
    "strictNullChecks": true,

    "baseUrl": "./src",

    "inlineSources": true,

    "typeRoots": ["./src/types", "./node_modules/@types"],
    "paths": {
      "x402": ["./src/types/x402"],
      "x402/*": ["./src/types/x402"],
      "x402-express": ["./src/types/x402"],
      "@/*": ["*"]
    }
  }
}
